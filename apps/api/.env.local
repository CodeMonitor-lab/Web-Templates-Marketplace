# --------------------------------------------------
# Application
# --------------------------------------------------
NODE_ENV=development
PORT=5000
HOST=0.0.0.0
API_PREFIX=/api/v1

# --------------------------------------------------
# Database
# --------------------------------------------------
MONGO_URI=mongodb://127.0.0.1:27017/web-templates-marketplace

# --------------------------------------------------
# Authentication
# --------------------------------------------------
JWT_SECRET=replace_with_a_long_random_secret_key
JWT_EXPIRES_IN=7d

JWT_REFRESH_SECRET=replace_with_another_secret_key
JWT_REFRESH_EXPIRES_IN=30d

BCRYPT_SALT_ROUNDS=10

# --------------------------------------------------
# Frontend
# --------------------------------------------------
CLIENT_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# --------------------------------------------------
# Cloudinary
# --------------------------------------------------
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=templates-marketplace

# --------------------------------------------------
# Uploads
# --------------------------------------------------
MAX_FILE_SIZE=10485760

# --------------------------------------------------
# Logging
# --------------------------------------------------
LOG_LEVEL=info